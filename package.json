{
  "name": "atlas-chat",
  "version": "0.1.14",
  "private": false,
  "author": "Olloyor",
  "description": "OpenRouter-first BYOK desktop chat client for free-tier model discovery and streaming.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olllayor/Atlas.git"
  },
  "bugs": {
    "url": "https://github.com/olllayor/Atlas/issues"
  },
  "homepage": "https://github.com/olllayor/Atlas#readme",
  "keywords": [
    "electron",
    "react",
    "openrouter",
    "byok",
    "desktop",
    "chat"
  ],
  "type": "module",
  "main": "out/main/index.cjs",
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc --noEmit && electron-vite build",
    "test": "node --import tsx --test tests/*.test.ts",
    "preview": "electron-vite preview",
    "rebuild": "electron-rebuild -f -w better-sqlite3,keytar",
    "icons:mac": "node generate-icon.cjs",
    "postinstall": "electron-builder install-app-deps",
    "release": "node scripts/release.mjs",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "package": "pnpm run icons:mac && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --x64 --arm64 --publish never"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "keytar"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.54",
    "@ai-sdk/openai": "^3.0.49",
    "@ai-sdk/openai-compatible": "^2.0.37",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@rive-app/react-webgl2": "^4.27.3",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-virtual": "^3.13.12",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.141",
    "ansi-to-react": "^6.2.6",
    "better-sqlite3": "12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "embla-carousel-react": "^8.6.0",
    "keytar": "7.9.0",
    "lucide-react": "1.7.0",
    "media-chrome": "^4.18.3",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-jsx-parser": "^2.4.1",
    "react-markdown": "10.1.0",
    "rehype-sanitize": "6.0.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tokenlens": "^1.3.1",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "^4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.3",
    "@tailwindcss/vite": "4.2.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/dagre": "^0.7.54",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "41.1.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "5.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "4.2.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vite": "7.3.1"
  },
  "build": {
    "appId": "com.olllayor.atlaschat",
    "productName": "Atlas",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "assets/icon.png"
      },
      {
        "from": "build/icon.icns",
        "to": "assets/icon.icns"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "entitlements": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "releaseType": "draft"
    }
  }
}
